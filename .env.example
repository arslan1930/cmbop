APP_NAME=SEOLinkBuildings
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

    DB_CONNECTION=sqlite
    # DB_HOST=127.0.0.1
    # DB_PORT=3306
    # DB_DATABASE=laravel
    # DB_USERNAME=root
    # DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_REPLY_TO_ADDRESS=
MAIL_SUPPORT_EMAIL=
MAIL_LOGO_URL=https://seolinkbuildings.com/assets/img/logo1.png
MAIL_QUEUE_CONNECTION=sync
ADMIN_EMAIL=

# Billing / invoices (PDF seller block + tax defaults)
BILLING_COMPANY_NAME="${APP_NAME}"
BILLING_LEGAL_NAME=
BILLING_ADDRESS_LINE1="71-75 Shelton Street"
BILLING_ADDRESS_LINE2="Covent Garden"
BILLING_ADDRESS_LINE3="London WC2H 9JQ"
BILLING_ADDRESS_COUNTRY="United Kingdom"
BILLING_SUPPORT_EMAIL="${MAIL_SUPPORT_EMAIL}"
BILLING_WEBSITE_URL="${APP_URL}"
BILLING_VAT_NUMBER=
BILLING_CURRENCY=EUR
BILLING_TAX_ENABLED=false
BILLING_TAX_RATE=0
BILLING_TAX_LABEL=VAT
BILLING_INVOICE_PREFIX=INV

TRUSTPILOT_REVIEW_URL=https://www.trustpilot.com/review/seolinkbuildings.com
SOCIAL_TWITTER_URL=
SOCIAL_LINKEDIN_URL=
SOCIAL_FACEBOOK_URL=

# Stripe (required for Credit/Debit card at checkout + Add Funds).
# Dashboard → Developers → API keys: pk_... / sk_...
# Dashboard → Developers → Webhooks: endpoint /api/stripe/webhook, secret whsec_...
# After setting keys on the server: php artisan config:clear
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (Laravel Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Publisher withdrawal platform fee (%). Keep UI/admin/email in sync via config/billing.php
WITHDRAWAL_FEE_PERCENT=0

# Content compliance (Google Docs article moderation at checkout)
CONTENT_MODERATION_ENABLED=true
CONTENT_MODERATION_THRESHOLD=70

# Publisher catalog enrichment (SEO metrics + homepage screenshots)
SITE_ENRICHMENT_ENABLED=true
SITE_METRICS_PROVIDER=manual
SITE_METRICS_FALLBACKS=manual
SITE_ENRICHMENT_FREQUENCY=weekly
SITE_ENRICHMENT_MAX_AGE_DAYS=90
SITE_SCREENSHOT_PROVIDER=thum_io
# AHREFS_API_KEY=
# MOZ_ACCESS_TOKEN=
# MOZ_ACCESS_ID=
# MOZ_SECRET_KEY=
# SEMRUSH_API_KEY=
# SCREENSHOTONE_ACCESS_KEY=
# SITE_SCREENSHOT_API_URL=
